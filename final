import random

#Get the player's name and make it look nice with a capital letter 
Name = input("WELCOME TO ROCK PAPER SCISSORS!, please enter your name: ").title()

# Ask if they need help; 'lower' makes sure 'YES' or 'Yes' both work
instructions_response = input(f"Hello {Name} :P, would you like to see the game instructions? ").lower()
if instructions_response == "yes":
    print("-- Paper beats Rock, Rock beats Scissors, Scissors beats Paper --")
elif instructions_response == "no":
    print("No instructions? Very well.. ")

#Setting up how many rounds to play
rounds_input = input("How many rounds? Enter digits or 'xxx' for infinite mode: ").lower()
infinite_mode = False
target_rounds = 0

if rounds_input == 'xxx':
    # If they type xxx, the game won't stop until they tell it to
    infinite_mode = True
    print("Infinite mode activated! Type 'xxx' anytime to quit :)")
else:
    # Change the text they typed into a number so we can count rounds
    target_rounds = int(rounds_input)
    print(f"Goal set to {target_rounds} rounds!")

# store our scores and history
history = []
stats = {"won": 0, "lost": 0, "tied": 0}
current_round = 0
options = ["rock", "paper", "scissors"]

# This loop keeps the game running round after round 
while infinite_mode or current_round < target_rounds:
    current_round += 1
    print(f"\n --Round {current_round}--")

    # Get the user's move
    user_choice = input("Please Choose Rock (R), Paper (P), Scissors (S) or XXX to quit: ").lower().strip()

    # If they want to quit early, we break out of the loop
    if user_choice == "xxx":
        current_round -= 1 # Subtract 1 so we don't count the 'quit' as a played round
        break

    # Make it easier for the player: 'r' becomes 'rock', etc.
    if user_choice == 'r':
        user_choice = "rock"
    elif user_choice == 'p':
        user_choice = "paper"
    elif user_choice == 's':
        user_choice = "scissors"

    # If they typed something weird, skip the rest and try again
    if user_choice not in options:
        print("That's not an option! Try again.")
        current_round -= 1
        continue

    # Let the computer pick a random move from the list
    comp_choice = random.choice(options)
    print(f"Computer went with: {comp_choice}")

    # Check who won using the game rules
    if user_choice == comp_choice:
        result = "tied"
        print("It's a draw!")
    elif (user_choice == "rock" and comp_choice == "scissors") or \
            (user_choice == "paper" and comp_choice == "rock") or \
            (user_choice == "scissors" and comp_choice == "paper"):
        result = "won"
        print(f"Nice! {user_choice} beats {comp_choice}.")
    else:
        result = "lost"
        print(f"Ouch... {comp_choice} beats {user_choice}.")

    # Save the result so we can calculate percentages later
    stats[result] += 1
    history.append(f"Round {current_round}: {user_choice} vs {comp_choice} -> {result}")

# End of the game: Showing the results
total_played = stats["won"] + stats["lost"] + stats["tied"]

# Only show stats if we actually played at least one round
if total_played > 0:
    # Work out the percentages (score divided by total times 100)
    win_pct = (stats["won"] / total_played) * 100
    loss_pct = (stats["lost"] / total_played) * 100
    tie_pct = (stats["tied"] / total_played) * 100

    print(f"\n--- Final Results for {Name} ---")
    # :.1f keeps the number simple with only 1 decimal place
    print(f"Wins: {win_pct:.1f}% | Losses: {loss_pct:.1f}% | Ties: {tie_pct:.1f}%")

    # Ask the user if they want to see the list of every round played
    wants_history = input("\nWant to see your full game history? (yes/no): ").lower()
    if wants_history == "yes":
        print("\n--- YOUR GAME HISTORY ---")
        for entry in history:
            print(entry)
else:
    print("\nWait, we didn't even play! Come back when you're ready.")

print(f"\nCatch ya later, {Name}!")
